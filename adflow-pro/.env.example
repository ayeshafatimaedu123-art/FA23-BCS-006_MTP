# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key
DATABASE_URL=postgresql://user:password@localhost:5432/adflow_pro

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars
REFRESH_TOKEN_EXPIRE=30d

# Mail Service (for notifications)
MAIL_SERVICE=gmail
MAIL_EMAIL=noreply@adflow.pro
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=AdFlow Pro

# AWS/Cloud Storage (if needed for backups)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Third Party APIs
YOUTUBE_API_KEY=your-youtube-api-key

# Cron Jobs
CRON_SECRET=your-cron-secret-key

# Admin Email
ADMIN_EMAIL=admin@adflow.pro


# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_NAME=AdFlow Pro
NEXT_PUBLIC_APP_URL=http://localhost:3000
